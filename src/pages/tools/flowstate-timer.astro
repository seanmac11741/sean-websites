        { ra: h2r(16.29), dec: d2r(75.76), mag: 4.2 },   // Eta UMi
      ],
      lines: [[0,1],[1,2],[2,3],[3,6],[6,4],[4,5],[5,3]],
    },
  ];

  // Background stars (random filler) — use ra/dec for consistency
  const BG_STARS: { ra: number; dec: number; r: number; a: number }[] = [];
  for (let i = 0; i < 400; i++) {
    BG_STARS.push({
      ra: Math.random() * Math.PI * 2,
      dec: Math.random() * d2r(90),
      r: Math.random() * 1.2 + 0.3,
      a: Math.random() * 0.6 + 0.2,
    });
  }

  function resizeCanvas() {
    starfieldCanvas.width = window.innerWidth;
    starfieldCanvas.height = window.innerHeight;
  }

  function magnitudeToRadius(mag: number): number {
    return Math.max(1, 4 - mag * 0.8);
  }

  // Stereographic projection centered on Polaris (north celestial pole)
  // Projects ra/dec onto a 2D plane. rotationAngle offsets RA for sky rotation.
  function stereoProject(ra: number, dec: number): { px: number; py: number } | null {
    const centerDec = POLARIS_DEC; // ~π/2
    const raOff = ra - rotationAngle;

    // Stereographic projection from pole
    const cosDec = Math.cos(dec);
    const sinDec = Math.sin(dec);
    const cosCDec = Math.cos(centerDec);
    const sinCDec = Math.sin(centerDec);
    const cosRa = Math.cos(raOff);

    const denom = sinCDec * sinDec + cosCDec * cosDec * cosRa;
    if (denom < 0.05) return null; // behind the projection

    const k = 1 / denom;
    const sx = k * cosDec * Math.sin(raOff);
    const sy = k * (cosCDec * sinDec - sinCDec * cosDec * cosRa);

    const w = starfieldCanvas.width;
    const h = starfieldCanvas.height;
    const cx = w / 2;
    const cy = h / 2;

    return {
      px: cx + sx * SCALE,
      py: cy - sy * SCALE,
    };
  }

  function drawStars(bgAlpha: number) {
    // Background stars
    for (const s of BG_STARS) {
      const proj = stereoProject(s.ra, s.dec);
      if (!proj) continue;
      ctx.beginPath();
      ctx.arc(proj.px, proj.py, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255, 255, 255, ${s.a * bgAlpha})`;
      ctx.fill();
    }

    // Constellation stars
    for (const c of CONSTELLATIONS) {
      for (const star of c.stars) {
        const proj = stereoProject(star.ra, star.dec);
        if (!proj) continue;
        const r = magnitudeToRadius(star.mag);
        ctx.beginPath();
        ctx.arc(proj.px, proj.py, r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${bgAlpha})`;
        ctx.fill();
      }
    }
  }

  function drawLines(bgAlpha: number) {
    ctx.strokeStyle = `rgba(255, 255, 255, ${0.15 * bgAlpha})`;
    ctx.lineWidth = 0.8;

    for (const c of CONSTELLATIONS) {
      for (const line of c.lines) {
        const a = stereoProject(c.stars[line[0]].ra, c.stars[line[0]].dec);
        const b = stereoProject(c.stars[line[1]].ra, c.stars[line[1]].dec);
        if (!a || !b) continue;
        ctx.beginPath();
        ctx.moveTo(a.px, a.py);
        ctx.lineTo(b.px, b.py);
        ctx.stroke();
      }
    }
  }

  // Constellation hover labels
  const HOVER_RADIUS = 50;
  let hoveredConstellation: string | null = null;
  let hoverX = 0;
  let hoverY = 0;

  function drawLabels() {
    if (!hoveredConstellation) return;
    ctx.font = '13px Inter, sans-serif';
    ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
    ctx.textAlign = 'center';
    ctx.fillText(hoveredConstellation, hoverX, hoverY - 15);
  }

  // mousemove for constellation hover labels (on window so it works regardless of pointer-events)
  window.addEventListener('mousemove', (e: MouseEvent) => {
    if (!starfieldVisible) return;
    hoveredConstellation = null;
    const mx = e.clientX;
    const my = e.clientY;

    for (const c of CONSTELLATIONS) {
      // Compute constellation center on screen
      let sumX = 0, sumY = 0, count = 0;
      for (const star of c.stars) {
        const proj = stereoProject(star.ra, star.dec);
        if (!proj) continue;
        sumX += proj.px;
        sumY += proj.py;
        count++;
      }
      if (count === 0) continue;
      const centerX = sumX / count;
      const centerY = sumY / count;
      const dist = Math.hypot(mx - centerX, my - centerY);
      if (dist < HOVER_RADIUS) {
        hoveredConstellation = c.name;
        hoverX = centerX;
        hoverY = centerY;
        break;
      }
    }
  });

  let dawnAmount = 0; // 0 = night (focus), 1 = dawn (break)

  function renderField() {
    const w = starfieldCanvas.width;
    const h = starfieldCanvas.height;

    // Background gradient
    const r = Math.round(10 + dawnAmount * 25);
    const g = Math.round(10 + dawnAmount * 20);
    const b = Math.round(15 + dawnAmount * 35);
    ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;
    ctx.fillRect(0, 0, w, h);

    const starAlpha = 1 - dawnAmount * 0.4;
    drawStars(starAlpha);
    drawLines(starAlpha);
    drawLabels();
  }

  window.addEventListener('resize', () => {
    if (starfieldVisible) {
      resizeCanvas();
      renderField();
    }
  });

  function startAutoRotation() {
    const ROTATION_SPEED = 0.00003; // radians per frame (very slow)
    let lastRotateTime: number | null = null;

    function rotateLoop(timestamp: number) {
      if (!lastRotateTime) lastRotateTime = timestamp;
      const dt = timestamp - lastRotateTime;
      lastRotateTime = timestamp;
      rotationAngle += ROTATION_SPEED * dt;
      renderField();
      autoRotateId = requestAnimationFrame(rotateLoop);
    }

    autoRotateId = requestAnimationFrame(rotateLoop);
  }

  function stopAutoRotation() {
    if (autoRotateId) {
      cancelAnimationFrame(autoRotateId);
      autoRotateId = null;
    }
  }

  function showStarfield() {
    if (starfieldVisible) return;
    starfieldVisible = true;
    resizeCanvas();
    renderField();
    starfieldCanvas.classList.remove('hidden');
    gsap.fromTo(starfieldCanvas, { opacity: 0 }, { opacity: 1, duration: 1.5, ease: 'power2.out' });
    startAutoRotation();
  }

  // === Mouse drag rotation (break mode only) ===
  let isDragging = false;
  let dragStartX = 0;

  starfieldCanvas.addEventListener('mousedown', (e: MouseEvent) => {
    if (mode !== 'break') return;
    isDragging = true;
    dragStartX = e.clientX;
    starfieldCanvas.style.cursor = 'grabbing';
  });

  window.addEventListener('mousemove', (e: MouseEvent) => {
    if (!isDragging) return;
    const dx = e.clientX - dragStartX;
    rotationAngle += dx * 0.003;
    dragStartX = e.clientX;
    renderField();
  });

  window.addEventListener('mouseup', () => {
    if (!isDragging) return;
    isDragging = false;
    starfieldCanvas.style.cursor = mode === 'break' ? 'grab' : 'default';
  });

  // === Touch drag rotation (break mode only, mobile) ===
  let touchStartX = 0;

  starfieldCanvas.addEventListener('touchstart', (e: TouchEvent) => {
    if (mode !== 'break') return;
    isDragging = true;
    touchStartX = e.touches[0].clientX;
  }, { passive: true });

  window.addEventListener('touchmove', (e: TouchEvent) => {
    if (!isDragging) return;
    const dx = e.touches[0].clientX - touchStartX;
    rotationAngle += dx * 0.003;
    touchStartX = e.touches[0].clientX;
    renderField();
  }, { passive: true });

  window.addEventListener('touchend', () => {
    isDragging = false;
  });
</script>
