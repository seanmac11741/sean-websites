---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin — Sean McConnell" description="Blog admin dashboard">
  <div id="admin-app" class="min-h-screen bg-dark text-white">
    <!-- Loading state -->
    <div id="loading-screen" class="flex items-center justify-center min-h-screen">
      <div class="text-center">
        <div class="w-8 h-8 border-2 border-accent border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-slate-400 text-sm">Loading...</p>
      </div>
    </div>

    <!-- Login screen -->
    <div id="login-screen" class="hidden flex items-center justify-center min-h-screen">
      <div class="bg-surface border border-white/10 rounded-2xl p-8 max-w-sm w-full mx-4">
        <h1 class="text-2xl font-bold text-white mb-2">Admin</h1>
        <p class="text-slate-400 text-sm mb-6">Sign in to manage blog posts.</p>
        <button
          id="google-signin-btn"
          class="w-full flex items-center justify-center gap-3 bg-white text-gray-800 font-medium py-3 px-4 rounded-lg hover:bg-gray-100 transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Sign in with Google
        </button>
      </div>
    </div>

    <!-- Unauthorized screen -->
    <div id="unauthorized-screen" class="hidden flex items-center justify-center min-h-screen">
      <div class="bg-surface border border-white/10 rounded-2xl p-8 max-w-sm w-full mx-4 text-center">
        <div class="text-4xl mb-4">🚫</div>
        <h1 class="text-xl font-bold text-white mb-2">Access Denied</h1>
        <p class="text-slate-400 text-sm mb-6">Your account is not authorized to access the admin panel.</p>
        <button id="signout-unauth-btn" class="text-accent hover:text-white text-sm transition-colors duration-200">
          Sign out
        </button>
      </div>
    </div>

    <!-- Admin dashboard -->
    <div id="dashboard-screen" class="hidden">
      <header class="border-b border-white/10 bg-surface/50 backdrop-blur-sm sticky top-0 z-40">
        <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <a href="/" class="text-slate-400 hover:text-white text-sm transition-colors duration-200">&larr; Back to site</a>
            <span class="text-white/20">|</span>
            <h1 class="text-white font-semibold">Blog Admin</h1>
          </div>
          <div class="flex items-center gap-4">
            <span id="user-email" class="text-slate-400 text-sm"></span>
            <button id="signout-btn" class="text-sm text-slate-400 hover:text-white border border-white/10 px-3 py-1.5 rounded-lg transition-colors duration-200">
              Sign out
            </button>
          </div>
        </div>
      </header>

      <div class="max-w-6xl mx-auto px-6 py-8 flex gap-8">
        <!-- Sidebar -->
        <aside class="w-56 shrink-0">
          <button
            id="new-post-btn"
            class="w-full bg-accent hover:bg-accent/80 text-white font-medium py-2.5 px-4 rounded-lg transition-colors duration-200 mb-6"
          >
            + New Post
          </button>
          <nav>
            <a href="/admin" class="block px-3 py-2 text-white bg-white/5 rounded-lg text-sm font-medium">
              Posts
            </a>
          </nav>
        </aside>

        <!-- Main content -->
        <main class="flex-1 min-w-0">
          <div id="posts-list" class="space-y-3">
            <div class="text-center py-16">
              <p class="text-slate-400 text-sm">No posts yet. Create your first post!</p>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>

  <script>
    import { auth, db, googleProvider, ADMIN_EMAIL } from '../../lib/firebase';
    import { signInWithPopup, signOut, onAuthStateChanged } from 'firebase/auth';
    import { collection, getDocs, deleteDoc, doc, orderBy, query } from 'firebase/firestore';

    const loadingScreen = document.getElementById('loading-screen')!;
    const loginScreen = document.getElementById('login-screen')!;
    const unauthorizedScreen = document.getElementById('unauthorized-screen')!;
    const dashboardScreen = document.getElementById('dashboard-screen')!;
    const userEmail = document.getElementById('user-email')!;
    const postsList = document.getElementById('posts-list')!;

    function showScreen(screen: HTMLElement) {
      [loadingScreen, loginScreen, unauthorizedScreen, dashboardScreen].forEach(
        (s) => s.classList.add('hidden')
      );
      screen.classList.remove('hidden');
    }

    async function loadPosts() {
      const q = query(collection(db, 'posts'), orderBy('updatedAt', 'desc'));
      const snapshot = await getDocs(q);

      if (snapshot.empty) {
        postsList.innerHTML = `
          <div class="text-center py-16">
            <p class="text-slate-400 text-sm">No posts yet. Create your first post!</p>
          </div>`;
        return;
      }

      postsList.innerHTML = '';
      snapshot.forEach((docSnap) => {
        const data = docSnap.data();
        const updatedAt = data.updatedAt?.toDate();
        const dateStr = updatedAt ? updatedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Unknown';
        const statusClass = data.status === 'published' ? 'bg-green-500/20 text-green-400' : 'bg-yellow-500/20 text-yellow-400';
        const statusLabel = data.status === 'published' ? 'Published' : 'Draft';

        const card = document.createElement('div');
        card.className = 'bg-surface border border-white/10 rounded-lg p-4 flex items-center justify-between hover:border-white/20 transition-colors duration-200';
        card.innerHTML = `
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-3 mb-1">
              <h3 class="text-white font-medium truncate">${data.title || 'Untitled'}</h3>
              <span class="text-xs px-2 py-0.5 rounded-full ${statusClass} shrink-0">${statusLabel}</span>
            </div>
            <p class="text-slate-500 text-xs">${dateStr} · /${data.slug || docSnap.id}</p>
          </div>
          <div class="flex items-center gap-2 ml-4 shrink-0">
            <a href="/admin/editor?slug=${docSnap.id}" class="text-sm text-slate-400 hover:text-white border border-white/10 px-3 py-1.5 rounded-lg transition-colors duration-200">Edit</a>
            <button data-delete="${docSnap.id}" class="text-sm text-red-400 hover:text-red-300 border border-white/10 px-3 py-1.5 rounded-lg transition-colors duration-200">Delete</button>
          </div>`;
        postsList.appendChild(card);
      });

      postsList.addEventListener('click', async (e) => {
        const btn = (e.target as HTMLElement).closest('[data-delete]');
        if (!btn) return;
        const slug = btn.getAttribute('data-delete')!;
        if (!confirm(`Delete post "${slug}"? This cannot be undone.`)) return;
        await deleteDoc(doc(db, 'posts', slug));
        loadPosts();
      });
    }

    onAuthStateChanged(auth, async (user) => {
      if (!user) {
        showScreen(loginScreen);
        return;
      }

      if (user.email !== ADMIN_EMAIL) {
        showScreen(unauthorizedScreen);
        return;
      }

      userEmail.textContent = user.email;
      showScreen(dashboardScreen);
      await loadPosts();
    });

    document.getElementById('google-signin-btn')!.addEventListener('click', async () => {
      try {
        await signInWithPopup(auth, googleProvider);
      } catch (err: any) {
        if (err.code !== 'auth/popup-closed-by-user') {
          console.error('Sign-in error:', err);
        }
      }
    });

    document.getElementById('new-post-btn')!.addEventListener('click', () => {
      window.location.href = '/admin/editor';
    });

    document.getElementById('signout-btn')!.addEventListener('click', () => signOut(auth));
    document.getElementById('signout-unauth-btn')!.addEventListener('click', () => signOut(auth));
  </script>
</Layout>
