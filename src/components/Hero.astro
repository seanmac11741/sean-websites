---
---

<section id="hero" class="min-h-screen flex items-center pt-20 pb-16">
  <div class="max-w-6xl mx-auto px-6 w-full grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-8 items-center">

    <div class="order-2 md:order-1">
      <div class="overflow-hidden mb-3">
        <h1 id="hero-name" class="text-6xl sm:text-7xl lg:text-8xl font-black text-white leading-none tracking-tight">
          Sean<br />McConnell
        </h1>
      </div>

      <div id="hero-tagline" class="flex items-center gap-1 text-xl sm:text-2xl font-semibold mb-8 h-9" style="color: var(--accent)">
        <span id="typewriter"></span><span class="typewriter-cursor"></span>
      </div>

      <div id="hero-btns" class="flex flex-wrap gap-4 mb-10">
        <a
          href="#skills"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm text-dark transition-all duration-200 hover:opacity-90 hover:-translate-y-0.5 active:translate-y-0"
          style="background-color: var(--accent)"
        >
          View my work ↓
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm text-white border border-white/20 hover:border-accent/60 hover:bg-white/5 transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0"
        >
          Get in touch
        </a>
      </div>

      <div id="hero-socials" class="flex items-center gap-5">
        <a href="https://github.com/seanmac11741" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-slate-400 hover:text-white transition-all duration-200 hover:scale-110">
          <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
        <a href="https://git.doit.wisc.edu/SEAN.MCCONNELL" target="_blank" rel="noopener noreferrer" aria-label="GitLab" class="text-slate-400 hover:text-white transition-all duration-200 hover:scale-110">
          <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor">
            <path d="M4.845.904C4.605.904 4.38 1.048 4.28 1.295L.05 13.61a.697.697 0 0 0 .255.782l11.695 8.498a.697.697 0 0 0 .817 0L24.513 14.39a.695.695 0 0 0 .255-.782L20.538 1.295a.697.697 0 0 0-.657-.39.697.697 0 0 0-.657.468L16.124 12H7.876L4.776 1.372A.697.697 0 0 0 4.845.904z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/sean-mcconnell-9032a7385/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-slate-400 hover:text-white transition-all duration-200 hover:scale-110">
          <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>

    <div id="hero-photo" class="order-1 md:order-2 flex justify-center">
      <div class="relative">
        <div class="absolute inset-0 rounded-full blur-3xl scale-110 opacity-40" style="background-color: var(--accent)"></div>
        <img
          src="/images/ProfilePictureSeanWhiteSweater.png"
          alt="Sean McConnell"
          class="relative w-56 h-56 sm:w-72 sm:h-72 md:w-80 md:h-80 rounded-full object-cover object-top border-2 border-white/10"
          style="box-shadow: 0 0 0 4px rgba(129,140,248,0.2)"
        />
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ delay: 0.1 });

  tl.from('#hero-name', {
    yPercent: 120,
    duration: 0.9,
    ease: 'power3.out',
  })
    .from(
      '#hero-tagline',
      { opacity: 0, y: 16, duration: 0.6, ease: 'power2.out' },
      '-=0.35',
    )
    .from(
      '#hero-btns > *',
      { opacity: 0, y: 16, stagger: 0.1, duration: 0.5, ease: 'power2.out' },
      '-=0.3',
    )
    .from(
      '#hero-socials > *',
      { opacity: 0, y: 8, stagger: 0.07, duration: 0.4, ease: 'power2.out' },
      '-=0.3',
    )
    .from(
      '#hero-photo',
      { opacity: 0, y: 20, duration: 0.7, ease: 'power2.out' },
      '-=0.8',
    );

  const titles = ['Software Engineer', 'Full-Stack Developer', 'Agentic Software Engineer', 'Web Developer', 'AI Engineer', 'Builder of Things', 'Marathon Runner'];
  let currentIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  const typewriterEl = document.getElementById('typewriter');

  function typeWriter() {
    if (!typewriterEl) return;
    const current = titles[currentIndex];
    if (isDeleting) {
      charIndex--;
      typewriterEl.textContent = current.slice(0, charIndex);
      if (charIndex === 0) {
        isDeleting = false;
        currentIndex = (currentIndex + 1) % titles.length;
        setTimeout(typeWriter, 400);
        return;
      }
      setTimeout(typeWriter, 35);
    } else {
      charIndex++;
      typewriterEl.textContent = current.slice(0, charIndex);
      if (charIndex === current.length) {
        setTimeout(() => {
          isDeleting = true;
          typeWriter();
        }, 2500);
        return;
      }
      setTimeout(typeWriter, 75);
    }
  }

  setTimeout(typeWriter, 1400);
</script>
