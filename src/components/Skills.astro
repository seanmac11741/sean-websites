---
type Skill = { name: string; years: number };
type Category = { title: string; skills: Skill[] };

const maxYears = 10;

const categories: Category[] = [
  {
    title: 'Languages',
    skills: [
      { name: 'JavaScript', years: 9 },
      { name: 'Python', years: 3 },
      { name: 'Java', years: 2 },
      { name: 'SQL', years: 10 },
      { name: 'Bash', years: 10 },
    ],
  },
  {
    title: 'Web Development',
    skills: [
      { name: 'Node.js', years: 9 },
      { name: 'React', years: 3 },
      { name: 'REST APIs', years: 8 },
      { name: 'Full Stack', years: 7 },
    ],
  },
  {
    title: 'Cloud & Infrastructure',
    skills: [
      { name: 'GCP / Firebase', years: 5 },
      { name: 'AWS', years: 2 },
      { name: 'Docker', years: 6 },
      { name: 'Terraform', years: 2 },
    ],
  },
  {
    title: 'DevOps & CI/CD',
    skills: [
      { name: 'CI/CD Pipelines', years: 8 },
      { name: 'Testing', years: 9 },
      { name: 'Linux', years: 10 },
      { name: 'Git', years: 10 },
    ],
  },
  {
    title: 'Messaging & Data',
    skills: [
      { name: 'RabbitMQ', years: 6 },
      { name: 'SQL Databases', years: 10 },
    ],
  },
  {
    title: 'AI & Automation',
    skills: [
      { name: 'GitHub Copilot', years: 4 },
      { name: 'Claude', years: 1 },
      { name: 'Agentic Engineering', years: 1 },
    ],
  },
];
---

<section id="skills" class="py-24 lg:py-32">
  <div class="max-w-6xl mx-auto px-6">

    <div class="overflow-hidden mb-16">
      <h2 id="skills-heading" class="text-4xl sm:text-5xl font-black text-white">Skills</h2>
    </div>

    {categories.map((cat, i) => (
      <div class="skills-category" data-category={cat.title}>
        <h3 class={`text-sm font-bold text-accent uppercase tracking-wider ${i === 0 ? 'mt-0' : 'mt-10'} mb-4`}>
          {cat.title}
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {cat.skills.map((skill) => (
            <div class="skill-card rounded-xl border border-white/10 bg-surface/40 p-4 flex flex-col hover:border-accent/50 hover:-translate-y-1 hover:bg-surface/80 transition-all duration-200 cursor-default">
              <span class="text-sm font-semibold text-white">{skill.name}</span>
              <div class="h-1 rounded-full bg-white/5 mt-3">
                <div class="h-1 rounded-full bg-accent" style={`width: ${(skill.years / maxYears) * 100}%`}></div>
              </div>
              <span class="text-xs text-slate-500 mt-2">{skill.years} {skill.years !== 1 ? 'yrs' : 'yr'}</span>
            </div>
          ))}
        </div>
      </div>
    ))}

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('#skills-heading', {
    scrollTrigger: { trigger: '#skills', start: 'top 78%', once: true },
    immediateRender: false,
    yPercent: 110,
    duration: 0.8,
    ease: 'power3.out',
  });

  document.querySelectorAll('.skills-category').forEach((group) => {
    gsap.from(group.querySelectorAll('.skill-card'), {
      scrollTrigger: { trigger: group, start: 'top 78%', once: true },
      immediateRender: false,
      opacity: 0,
      y: 28,
      stagger: 0.05,
      duration: 0.5,
      ease: 'power2.out',
    });
  });
</script>
