<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const nav = document.getElementById('main-nav');
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const lines = document.querySelectorAll('.hamburger-line');

  if (nav) {
    ScrollTrigger.create({
      start: 'top -60',
      onEnter: () => {
        gsap.to(nav, {
          backgroundColor: 'rgba(10, 10, 15, 0.92)',
          backdropFilter: 'blur(12px)',
          duration: 0.3,
          ease: 'power2.out',
        });
      },
      onLeaveBack: () => {
        gsap.to(nav, {
          backgroundColor: 'transparent',
          backdropFilter: 'none',
          duration: 0.3,
          ease: 'power2.out',
        });
      },
    });
  }

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));

      if (!isOpen) {
        gsap.set(lines[0], { transformOrigin: 'center' });
        gsap.set(lines[2], { transformOrigin: 'center' });
        gsap.to(lines[0], { rotation: 45, y: 8, duration: 0.25 });
        gsap.to(lines[1], { opacity: 0, duration: 0.2 });
        gsap.to(lines[2], { rotation: -45, y: -8, duration: 0.25 });
      } else {
        gsap.to(lines[0], { rotation: 0, y: 0, duration: 0.25 });
        gsap.to(lines[1], { opacity: 1, duration: 0.2 });
        gsap.to(lines[2], { rotation: 0, y: 0, duration: 0.25 });
      }
    });

    document.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        gsap.to(lines[0], { rotation: 0, y: 0, duration: 0.25 });
        gsap.to(lines[1], { opacity: 1, duration: 0.2 });
        gsap.to(lines[2], { rotation: 0, y: 0, duration: 0.25 });
      });
    });
  }
</script>

<script>
  import { auth, ADMIN_EMAIL } from '../lib/firebase';
  import { onAuthStateChanged } from 'firebase/auth';

  const adminLink = document.getElementById('admin-nav-link');
  const adminLinkMobile = document.getElementById('admin-nav-link-mobile');

  onAuthStateChanged(auth, (user) => {
    const show = user?.email === ADMIN_EMAIL;
    adminLink?.classList.toggle('hidden', !show);
    adminLinkMobile?.classList.toggle('hidden', !show);
  });
</script>
