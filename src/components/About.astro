---
import { Image } from 'astro:assets';
import mountainsPhoto from '../assets/images/CasualMountainsSean.jpg';

const startDate = new Date(2015, 3, 23);
const now = new Date();

const years = now.getFullYear() - startDate.getFullYear() - (now < new Date(now.getFullYear(), startDate.getMonth(), startDate.getDate()) ? 1 : 0);

let months = now.getMonth() - startDate.getMonth();
let days = now.getDate() - startDate.getDate();
if (days < 0) {
  months--;
  const prevMonth = new Date(now.getFullYear(), now.getMonth(), 0);
  days += prevMonth.getDate();
}
if (months < 0) months += 12;

const hours = now.getHours();
const minutes = now.getMinutes();
const seconds = now.getSeconds();

const pad = (n: number) => String(n).padStart(2, '0');
---

<section id="about" class="py-24 lg:py-32">
  <div class="max-w-6xl mx-auto px-6">

    <div class="overflow-hidden mb-16">
      <h2 id="about-heading" class="text-4xl sm:text-5xl font-black text-white">About</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-start">

      <div id="about-text">
        <p class="text-slate-300 text-lg leading-relaxed mb-6">
          Software Engineer at UW-Madison with {years} years of experience building technical solutions in Higher Education.
        </p>
        <p class="text-slate-400 leading-relaxed">
          Right now I'm building secure, AI-powered integration solutions for student data at UW-Madison on AWS. I love learning in public, tackling hard problems, and helping other engineers level up.
        </p>
      </div>

      <div id="about-photo" class="flex justify-center md:justify-end">
        <Image
          src={mountainsPhoto}
          alt="Sean McConnell hiking in the mountains"
          width={576}
          height={640}
          class="w-72 h-80 rounded-2xl object-cover object-center border border-white/10"
        />
      </div>

    </div>

    <div id="about-highlights" class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-16 pt-12 border-t border-white/10">
      <div id="experience-timer" class="about-highlight text-center sm:text-left relative cursor-default">
        <div id="timer-default" class="transition-opacity duration-300">
          <div id="timer-years" class="text-3xl font-black mb-1 timer-digit" style="color: var(--accent)">{years}+</div>
          <div class="text-sm text-slate-400 font-medium">Years of Experience</div>
        </div>
        <div id="timer-hover" class="absolute inset-0 opacity-0 transition-opacity duration-300 pointer-events-none">
          <div class="text-sm font-semibold text-slate-300 mb-1.5">Exact years of experience as a software engineer</div>
          <div class="flex items-center justify-center sm:justify-start gap-2 text-xs text-slate-500">
            <span><span id="timer-hover-years" class="timer-digit font-bold" style="color: var(--accent)">{years}</span> yrs</span>
            <span class="text-white/10">|</span>
            <span><span id="timer-months" class="timer-digit font-bold" style="color: var(--accent)">{pad(months)}</span> mo</span>
            <span class="text-white/10">|</span>
            <span><span id="timer-days" class="timer-digit font-bold" style="color: var(--accent)">{pad(days)}</span> days</span>
            <span class="text-white/10">|</span>
            <span><span id="timer-hours" class="timer-digit font-bold" style="color: var(--accent)">{pad(hours)}</span> hrs</span>
            <span class="text-white/10">|</span>
            <span><span id="timer-minutes" class="timer-digit font-bold" style="color: var(--accent)">{pad(minutes)}</span> min</span>
            <span class="text-white/10">|</span>
            <span><span id="timer-seconds" class="timer-digit font-bold" style="color: var(--accent)">{pad(seconds)}</span> sec</span>
          </div>
        </div>
      </div>
      <div id="wisconsin-card" class="about-highlight text-center sm:text-left relative cursor-default">
        <div id="wisconsin-default" class="transition-opacity duration-300">
          <div class="text-3xl font-black mb-1" style="color: var(--accent)">Wisconsin</div>
          <div class="text-sm text-slate-400 font-medium">Based in</div>
        </div>
        <div id="wisconsin-hover" class="absolute inset-0 opacity-0 transition-opacity duration-300 pointer-events-none">
          <div id="weather-temp" class="text-xl font-bold mb-1" style="color: var(--accent)"></div>
          <div class="text-xs text-slate-400 font-medium">Madison, WI</div>
        </div>
      </div>
      <div id="aicloud-card" class="about-highlight text-center sm:text-left relative cursor-default">
        <div id="aicloud-default" class="transition-opacity duration-300">
          <div class="text-3xl font-black mb-1" style="color: var(--accent)">AI & Cloud</div>
          <div class="text-sm text-slate-400 font-medium">Specialty</div>
        </div>
        <div id="aicloud-hover" class="absolute inset-0 opacity-0 transition-opacity duration-300 pointer-events-none">
          <div class="flex items-center justify-center sm:justify-start gap-1.5 mb-1.5">
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none">
              <path d="M9 12l2 2 4-4" stroke="#FBBF24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 2l2.4 3.6L18 4.8l-.6 3.8 3.6 1.4-2.4 3L21 16l-3.6 1.2L18 21l-3.6-.6L12 24l-2.4-3.6L6 21l.6-3.8L3 16l2.4-3L3 8l3.6-1.2L6 3l3.6.6L12 2z" fill="#FBBF24"/>
              <path d="M9 12l2 2 4-4" stroke="#0A0A0F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-sm font-semibold" style="color: #FBBF24">AWS Certified</span>
          </div>
          <div class="text-xs text-slate-400 font-medium">GCP · LLMs · RAG · Agents</div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('#about-heading', {
    scrollTrigger: { trigger: '#about', start: 'top 78%', once: true },
    immediateRender: false,
    yPercent: 110,
    duration: 0.8,
    ease: 'power3.out',
  });

  gsap.from('#about-text', {
    scrollTrigger: { trigger: '#about', start: 'top 70%', once: true },
    immediateRender: false,
    opacity: 0,
    y: 30,
    duration: 0.8,
    ease: 'power2.out',
  });

  gsap.from('#about-photo', {
    scrollTrigger: { trigger: '#about', start: 'top 70%', once: true },
    immediateRender: false,
    opacity: 0,
    x: 30,
    duration: 0.8,
    ease: 'power2.out',
  });

  gsap.from('.about-highlight', {
    scrollTrigger: { trigger: '#about-highlights', start: 'top 82%', once: true },
    immediateRender: false,
    opacity: 0,
    y: 20,
    stagger: 0.15,
    duration: 0.6,
    ease: 'power2.out',
  });

  const START = new Date(2015, 3, 23);

  function pad(n: number): string {
    return String(n).padStart(2, '0');
  }

  function calcDuration() {
    const now = new Date();

    let y = now.getFullYear() - START.getFullYear();
    let m = now.getMonth() - START.getMonth();
    let d = now.getDate() - START.getDate();

    if (d < 0) {
      m--;
      const prevMonth = new Date(now.getFullYear(), now.getMonth(), 0);
      d += prevMonth.getDate();
    }
    if (m < 0) {
      y--;
      m += 12;
    }

    return {
      years: y,
      months: m,
      days: d,
      hours: now.getHours(),
      minutes: now.getMinutes(),
      seconds: now.getSeconds(),
    };
  }

  function updateTimer() {
    const d = calcDuration();
    const el = (id: string) => document.getElementById(id);
    el('timer-years')!.textContent = d.years + '+';
    el('timer-hover-years')!.textContent = String(d.years);
    el('timer-months')!.textContent = pad(d.months);
    el('timer-days')!.textContent = pad(d.days);
    el('timer-hours')!.textContent = pad(d.hours);
    el('timer-minutes')!.textContent = pad(d.minutes);
    el('timer-seconds')!.textContent = pad(d.seconds);
  }

  updateTimer();
  setInterval(updateTimer, 1000);

  const timer = document.getElementById('experience-timer')!;
  const defaultView = document.getElementById('timer-default')!;
  const hoverView = document.getElementById('timer-hover')!;

  timer.addEventListener('mouseenter', () => {
    defaultView.style.opacity = '0';
    hoverView.style.opacity = '1';
  });
  timer.addEventListener('mouseleave', () => {
    defaultView.style.opacity = '1';
    hoverView.style.opacity = '0';
  });

  let timerTapped = false;
  timer.addEventListener('touchstart', (e) => {
    e.preventDefault();
    timerTapped = !timerTapped;
    defaultView.style.opacity = timerTapped ? '0' : '1';
    hoverView.style.opacity = timerTapped ? '1' : '0';
  }, { passive: false });

  function wmoToCondition(code: number): { label: string; icon: string } {
    if (code === 0) return { label: 'Clear', icon: '\u2600\uFE0F' };
    if (code <= 3) return { label: 'Cloudy', icon: '\u2601\uFE0F' };
    if (code <= 49) return { label: 'Fog', icon: '\uD83C\uDF2B\uFE0F' };
    if (code <= 59) return { label: 'Drizzle', icon: '\uD83C\uDF27\uFE0F' };
    if (code <= 69) return { label: 'Rain', icon: '\uD83C\uDF27\uFE0F' };
    if (code <= 79) return { label: 'Snow', icon: '\u2744\uFE0F' };
    if (code <= 84) return { label: 'Rain', icon: '\uD83C\uDF27\uFE0F' };
    if (code <= 86) return { label: 'Snow', icon: '\u2744\uFE0F' };
    if (code <= 99) return { label: 'Storm', icon: '\u26C8\uFE0F' };
    return { label: 'Cloudy', icon: '\u2601\uFE0F' };
  }

  const CACHE_KEY = 'weather-madison';
  const CACHE_TTL = 30 * 60 * 1000;

  async function fetchWeather() {
    const cached = localStorage.getItem(CACHE_KEY);
    if (cached) {
      const { data, ts } = JSON.parse(cached);
      if (Date.now() - ts < CACHE_TTL) {
        return data as { temp: number; code: number };
      }
    }

    const url = 'https://api.open-meteo.com/v1/forecast?latitude=43.0731&longitude=-89.4012&current=temperature_2m,weather_code&temperature_unit=fahrenheit';
    const res = await fetch(url);
    const json = await res.json();
    const data = {
      temp: Math.round(json.current.temperature_2m),
      code: json.current.weather_code,
    };
    localStorage.setItem(CACHE_KEY, JSON.stringify({ data, ts: Date.now() }));
    return data;
  }

  async function loadWeather() {
    const tempEl = document.getElementById('weather-temp')!;
    try {
      const { temp, code } = await fetchWeather();
      const { label, icon } = wmoToCondition(code);
      tempEl.textContent = `${icon} ${temp}\u00B0F ${label}`;
    } catch {
      tempEl.textContent = 'Madison, WI';
    }
  }

  loadWeather();

  function setupHoverCard(cardId: string, defaultId: string, hoverId: string) {
    const card = document.getElementById(cardId)!;
    const def = document.getElementById(defaultId)!;
    const hov = document.getElementById(hoverId)!;

    card.addEventListener('mouseenter', () => {
      def.style.opacity = '0';
      hov.style.opacity = '1';
    });
    card.addEventListener('mouseleave', () => {
      def.style.opacity = '1';
      hov.style.opacity = '0';
    });

    let tapped = false;
    card.addEventListener('touchstart', (e) => {
      e.preventDefault();
      tapped = !tapped;
      def.style.opacity = tapped ? '0' : '1';
      hov.style.opacity = tapped ? '1' : '0';
    }, { passive: false });
  }

  setupHoverCard('wisconsin-card', 'wisconsin-default', 'wisconsin-hover');
  setupHoverCard('aicloud-card', 'aicloud-default', 'aicloud-hover');
</script>
